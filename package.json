{
  "name": "@andrewpopov/feature-flags-kit",
  "version": "0.1.2",
  "description": "Framework- and DB-agnostic feature flags: a pure store -> environment -> default evaluator, typed registry, sync and async front ends with last-known-good degradation, and thin SQL/JSON-blob store adapters.",
  "author": "Andrew Popov",
  "license": "MIT",
  "repository": { "type": "git", "url": "git+https://github.com/andrewpopov/feature-flags-kit.git" },
  "bugs": { "url": "https://github.com/andrewpopov/feature-flags-kit/issues" },
  "homepage": "https://github.com/andrewpopov/feature-flags-kit#readme",
  "keywords": [
    "feature-flags",
    "flags",
    "evaluator",
    "framework-agnostic",
    "typescript"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify:pack": "node scripts/verify-pack.mjs",
    "verify:dist-fresh": "node scripts/verify-dist-fresh.mjs",
    "verify": "npm run typecheck && npm test && npm run build && npm run verify:pack",
    "release:note": "release-kit note",
    "release:notes": "release-kit notes",
    "release:bump": "release-kit bump",
    "release:cut": "release-kit cut",
    "release:check": "release-kit check",
    "release:hygiene": "release-kit hygiene"
  },
  "devDependencies": {
    "@andrewpopov/release-kit": "github:andrewpopov/release-kit#v0.2.0",
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.10"
  }
}
